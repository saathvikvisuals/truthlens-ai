MONGO_URL=mongodb://localhost:27017/truthlens
DB_NAME=truthlens

# NEVER use * in production: with allow_credentials=True this lets any site
# make authenticated cross-origin requests. Set to a comma-separated list of
# your real frontend origin(s), e.g. https://yourapp.com
CORS_ORIGINS=https://yourapp.com

# Required in production: shared secret clients must send as the X-API-Key
# header on /api/analyze-* and /api/stats. If left blank, auth is disabled
# (dev/demo mode only).
API_KEY=

# Max requests per minute per API key (or per client IP if no key sent),
# enforced on the /api/analyze-* routes since they call paid LLM APIs.
RATE_LIMIT_PER_MINUTE=20

# At least one real AI provider key is required for analysis.
# Keep real values in backend/.env locally and Vercel Environment Variables in production.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY can be used instead of GEMINI_API_KEY.
GOOGLE_API_KEY=

# Optional: one shared key if your Emergent integration account routes providers through it.
EMERGENT_LLM_KEY=

# Default true: fail clearly when no provider key is configured.
# Set false only for local demo mode.
STRICT_AI_PROVIDERS=true

# Optional: Neo4j-backed knowledge graph (claims, sources, providers, and the
# relationships between them). If unset, the app falls back to a static
# per-request graph shape and every graph_store method is a no-op.
# Free managed option: Neo4j AuraDB (https://neo4j.com/product/auradb/) free tier.
# Local dev option: docker run -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/<password> neo4j:5-community
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional Mongo connection tuning (defaults shown).
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000
# Optional: path to a custom CA bundle for MongoDB TLS. If unset and MONGO_URL
# uses mongodb+srv://, certifi's bundled CA store is used automatically.
MONGO_TLS_CA_FILE=
